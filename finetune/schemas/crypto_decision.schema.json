{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-inference-server.local/finetune/schemas/crypto_decision.schema.json",
  "title": "CryptoDecisionV0",
  "description": "Trading decision output contract for the crypto-trader pipeline. Owned by this project. Maps cleanly to crypto-trader/bot/strategies/base.py Signal via: Signal.direction = argmax(label != 'HOLD').label.lower(); Signal.confidence = global_confidence; Signal.timefm_score = timefm_score; Signal.news_score = news_score.",
  "type": "object",
  "required": [
    "schema_version",
    "symbol",
    "interval",
    "summary",
    "global_confidence",
    "choice_assessments",
    "uncertainty_flags",
    "trade_blockers",
    "rationale",
    "timefm_score",
    "news_score"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "crypto_decision_v0"
    },
    "symbol": {
      "type": "string",
      "minLength": 1,
      "description": "Trading pair, e.g. 'BTC/USDT'."
    },
    "interval": {
      "type": "string",
      "minLength": 1,
      "description": "Bar interval, e.g. '1h', '4h', '1d'."
    },
    "summary": {
      "type": "string",
      "minLength": 50,
      "maxLength": 500
    },
    "global_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "choice_assessments": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "description": "2 entries (LONG/SHORT) for trend strategies, 3 entries (LONG/SHORT/HOLD) for range-aware strategies. Probabilities sum to 1.0 ± 0.01.",
      "items": {
        "type": "object",
        "required": ["label", "probability", "confidence", "evidence", "data_coverage", "key_points"],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "enum": ["LONG", "SHORT", "HOLD"]
          },
          "probability": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": {
            "type": "object",
            "required": ["reliability", "diversity", "recency", "overall_strength"],
            "additionalProperties": false,
            "properties": {
              "reliability": { "type": "number", "minimum": 0, "maximum": 1 },
              "diversity":   { "type": "number", "minimum": 0, "maximum": 1 },
              "recency":     { "type": "number", "minimum": 0, "maximum": 1 },
              "overall_strength": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "data_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
          "contradictions": {
            "type": "array",
            "items": { "type": "string", "maxLength": 500 }
          },
          "key_points": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "maxLength": 500 }
          }
        }
      }
    },
    "uncertainty_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "thin_evidence_long",
          "thin_evidence_short",
          "high_disagreement",
          "stale_data",
          "macro_event_imminent",
          "regime_uncertain",
          "low_volume",
          "high_volatility_spike"
        ]
      }
    },
    "trade_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "wide_spread",
          "thin_book",
          "exit_depth_high_risk",
          "stale_quote",
          "exchange_outage_risk",
          "funding_extreme",
          "data_coverage_low",
          "orderbook_unavailable"
        ]
      }
    },
    "rationale": {
      "type": "string",
      "minLength": 100,
      "maxLength": 4000
    },
    "timefm_score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1,
      "description": "TimesFM directional score in [-1, 1]. Negative = bearish, positive = bullish. 0 if not consulted (but field still required for schema)."
    },
    "news_score": {
      "type": "number",
      "minimum": -1,
      "maximum": 1,
      "description": "News sentiment score in [-1, 1]. 0 if no news ingested."
    }
  }
}
