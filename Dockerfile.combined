# Unified GPU server: Qwen + Whisper + TimesFM on Tesla P40
# Stage 1: Compile C++ servers
FROM nvidia/cuda:12.8.0-devel-ubuntu22.04 AS builder

RUN apt-get update && apt-get install -y \
    git cmake build-essential python3 python3-pip curl ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Ivy Bridge ISA flags (no AVX2, no FMA, no BMI1/BMI2, no AVX512)
ENV IVY_CFLAGS="-march=x86-64 -msse4.2 -mavx -mno-avx2 -mno-fma -mno-avx512f -mno-bmi -mno-bmi2"

# --- Build llama.cpp (upstream + local patch series) ---
# See main Dockerfile for full strategy notes. Summary: clone upstream
# ggml-org/llama.cpp at the pinned SHA, apply patches/llama-cpp/0001
# (TurboQuant-only — MTP/Qwen35 dropped, now upstream via PR #22673 + fixes),
# clone Luce-Org/lucebox-hub at its pinned SHA into vendor/lucebox-hub/, then
# apply 0002–0006 + 0008–0010 (Phase 0g/0h dflash compile+link+bridge +
# Pascal CUDA fix; 0007 dropped — was lucebox LFS symlink fixup, now no-op).
ARG LLAMA_UPSTREAM_URL=https://github.com/ggml-org/llama.cpp.git
ARG LLAMA_UPSTREAM_SHA=a135ec0baa1bcf7eb0437c9fd04920f87cf33ace
ARG LUCEBOX_URL=https://github.com/Luce-Org/lucebox-hub.git
ARG LUCEBOX_SHA=6fe0d9a0a
WORKDIR /build/llama.cpp
RUN git init -q . && \
    git remote add origin "$LLAMA_UPSTREAM_URL" && \
    git -c protocol.version=2 fetch --depth 1 origin "$LLAMA_UPSTREAM_SHA" && \
    git checkout -q FETCH_HEAD && \
    test "$(git rev-parse HEAD)" = "$LLAMA_UPSTREAM_SHA"

COPY patches/llama-cpp/ /build/patches/llama-cpp/
RUN git apply --whitespace=nowarn /build/patches/llama-cpp/0001-turboquant-base.patch
RUN git clone "$LUCEBOX_URL" vendor/lucebox-hub && \
    git -C vendor/lucebox-hub checkout -q "$LUCEBOX_SHA" && \
    rm -rf vendor/lucebox-hub/.git
RUN for p in /build/patches/llama-cpp/0002-*.patch \
              /build/patches/llama-cpp/0003-*.patch \
              /build/patches/llama-cpp/0004-*.patch \
              /build/patches/llama-cpp/0005-*.patch \
              /build/patches/llama-cpp/0006-*.patch \
              /build/patches/llama-cpp/0008-*.patch \
              /build/patches/llama-cpp/0009-*.patch \
              /build/patches/llama-cpp/0010-*.patch; do \
      echo "applying $(basename $p)"; \
      git apply --whitespace=nowarn "$p"; \
    done
RUN cmake -B build \
    -DGGML_CUDA=ON \
    -DCMAKE_CUDA_ARCHITECTURES=61 \
    -DCMAKE_BUILD_TYPE=Release \
    -DGGML_NATIVE=OFF \
    -DGGML_CUDA_NO_VMM=ON \
    -DGGML_CUDA_FORCE_MMQ=ON \
    -DGGML_AVX=ON \
    -DGGML_AVX2=OFF \
    -DGGML_AVX512=OFF \
    -DGGML_FMA=OFF \
    -DGGML_F16C=OFF \
    -DGGML_BMI2=OFF \
    -DCMAKE_C_FLAGS="$IVY_CFLAGS" \
    -DCMAKE_CXX_FLAGS="$IVY_CFLAGS" \
    -DCMAKE_CUDA_FLAGS="-Wno-deprecated-gpu-targets" \
    -DLLAMA_SERVER=ON \
    -DLLAMA_FFMPEG=ON \
    -DLLAMA_DFLASH=ON \
    -DLLAMA_BUILD_EXAMPLES=OFF \
    -DLLAMA_BUILD_TESTS=OFF \
    && cmake --build build --config Release -j$(nproc)

# --- Build whisper.cpp ---
WORKDIR /build/whisper.cpp
RUN git clone --depth 1 https://github.com/ggerganov/whisper.cpp.git .
RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/lib/x86_64-linux-gnu/libcuda.so.1 2>/dev/null || true
RUN cmake -B build \
    -DGGML_CUDA=ON \
    -DCMAKE_CUDA_ARCHITECTURES=61 \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_EXE_LINKER_FLAGS="-L/usr/local/cuda/lib64/stubs" \
    -DGGML_NATIVE=OFF \
    -DGGML_AVX=ON \
    -DGGML_AVX2=OFF \
    -DGGML_AVX512=OFF \
    -DGGML_FMA=OFF \
    -DGGML_F16C=OFF \
    -DGGML_BMI2=OFF \
    -DCMAKE_C_FLAGS="$IVY_CFLAGS" \
    -DCMAKE_CXX_FLAGS="$IVY_CFLAGS" \
    -DCMAKE_CUDA_FLAGS="-Wno-deprecated-gpu-targets" \
    -DWHISPER_BUILD_EXAMPLES=ON \
    -DWHISPER_BUILD_SERVER=ON \
    -DWHISPER_BUILD_TESTS=OFF
RUN cmake --build /build/whisper.cpp/build --config Release --target whisper-server -j$(nproc)

# Collect shared libs.
# Order matters: whisper.cpp bundles its own ggml and produces libggml-cuda.so
# without TurboQuant symbols. Copy whisper libs first, then llama libs so that
# llama's (larger, with turbo-innerq exports) wins any filename collision.
RUN mkdir -p /build/libs && \
    find /build/whisper.cpp -name "*.so*" -exec cp -a {} /build/libs/ \; && \
    find /build/llama.cpp -name "*.so*" -exec cp -a {} /build/libs/ \;

# Stage 2: Final image — C++ binaries + Python/PyTorch + TimesFM
FROM nvidia/cuda:12.8.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HF_HOME=/models/huggingface

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev git libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# C++ binaries + shared libs
COPY --from=builder /build/libs/ /usr/local/lib/
COPY --from=builder /build/llama.cpp/build/bin/llama-server /usr/local/bin/
COPY --from=builder /build/whisper.cpp/build/bin/whisper-server /usr/local/bin/
RUN ldconfig

# Python: PyTorch 2.4.1 (last version supporting P40 sm_61)
RUN pip3 install --no-cache-dir --upgrade pip
RUN pip install --no-cache-dir torch==2.4.1 --index-url https://download.pytorch.org/whl/cu121

# Python: TimesFM
WORKDIR /app
RUN git clone --depth 1 https://github.com/google-research/timesfm.git /app/timesfm
RUN cd /app/timesfm && pip install --no-cache-dir "."

COPY server.py /app/server.py
COPY timesfm_worker.py /app/timesfm_worker.py
COPY system-prompt.txt /app/system-prompt.txt

EXPOSE 8080
CMD ["python3", "/app/server.py"]
