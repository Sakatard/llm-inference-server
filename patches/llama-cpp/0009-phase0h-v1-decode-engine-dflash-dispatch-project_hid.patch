From 5eaf011931f1d8f3ffa077b9c0c6f3490cb9a41d Mon Sep 17 00:00:00 2001
From: Sakatard <Sakatard@me.com>
Date: Mon, 18 May 2026 21:43:31 +0800
Subject: [PATCH 8/9] 
 0009-phase0h-v1-decode-engine-dflash-dispatch-project_hid.patch

---
 tools/server/llama_dflash_bridge.cpp | 19 ++++++++++---------
 tools/server/server.cpp              | 17 +++++++++++++++++
 2 files changed, 27 insertions(+), 9 deletions(-)

diff --git a/tools/server/llama_dflash_bridge.cpp b/tools/server/llama_dflash_bridge.cpp
index 7bea9ef1..3404e154 100644
--- a/tools/server/llama_dflash_bridge.cpp
+++ b/tools/server/llama_dflash_bridge.cpp
@@ -131,16 +131,17 @@ bool LlamaToDFlashTarget::embed_tokens(const int32_t * tokens, int n,
 bool LlamaToDFlashTarget::project_hidden_to_tokens(const float * hidden,
                                                     int n_tokens,
                                                     std::vector<int32_t> & tokens_out) {
-    // TODO Phase 0h v1: apply model.output_norm + model.output to project.
-    // Same access problem as embed_tokens — lm_head weights aren't on the public API.
+    // Phase 0h v1: STUB. Returns mask_token_id for every position so dflash's
+    // verify_batch rejects the drafter's predictions → spec-decode falls
+    // through to autoregressive decode on the target. Functional but no speedup.
     //
-    // Workaround: dflash's drafter normally calls this AFTER it has computed
-    // hidden states. We could instead push the hidden via a dummy llama_batch
-    // with `embeddings_only` mode and read logits, then argmax.
-    //
-    // v0 stub: argmax over zeros → token 0 (or eos). Triggers immediate
-    // drafter rejection → spec-decode falls through to autoregressive on target.
-    tokens_out.assign((size_t) n_tokens, 0);
+    // v2 will build a real ggml graph: hidden → output_norm (RMSNorm) →
+    // output (lm_head Linear) → argmax. Needs scratch context + backend buffer
+    // + cached weight references. ~150 LoC. Tracked in Phase 0h v2 task.
+    (void) hidden;
+    if (n_tokens <= 0) return false;
+    const int mask_id = mask_token_id();
+    tokens_out.assign((size_t) n_tokens, mask_id);
     return true;
 }
 
diff --git a/tools/server/server.cpp b/tools/server/server.cpp
index c82f1179..af528ca5 100644
--- a/tools/server/server.cpp
+++ b/tools/server/server.cpp
@@ -112,6 +112,23 @@ int main(int argc, char ** argv) {
         params.model_alias.insert(params.model.name);
     }
 
+    // Phase 0h: --decode-engine flag dispatch.
+#ifdef LLAMA_HAS_DFLASH
+    if (params.decode_engine == "dflash") {
+        SRV_INF("%s", "Phase 0h: --decode-engine dflash recognized — LLAMA_HAS_DFLASH=1.\n");
+        SRV_INF("%s", "Phase 0h: LlamaToDFlashTarget bridge linked. Real run_dflash_spec_decode\n");
+        SRV_INF("%s", "Phase 0h: dispatch from server request flow is v1 work — current path uses standard llama_decode.\n");
+        SRV_INF("%s", "Phase 0h: dflash kernels + tree-op ggml extensions present in this binary;\n");
+        SRV_INF("%s", "Phase 0h: see finetune/REVIEWS/phase0g_milestone.md + phase0h_integration_plan.md\n");
+    } else if (params.decode_engine != "legacy") {
+        SRV_INF("decode-engine '%s' unrecognized — falling back to legacy llama_decode\n", params.decode_engine.c_str());
+    }
+#else
+    if (params.decode_engine != "legacy") {
+        SRV_INF("decode-engine '%s' requires LLAMA_DFLASH=ON build — falling back to legacy\n", params.decode_engine.c_str());
+    }
+#endif
+
     // struct that contains llama context and inference
     server_context ctx_server;
 
