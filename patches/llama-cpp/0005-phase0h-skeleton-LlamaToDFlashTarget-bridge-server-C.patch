diff --git a/tools/server/llama_dflash_bridge.cpp b/tools/server/llama_dflash_bridge.cpp
new file mode 100644
index 00000000..74ab717f
--- /dev/null
+++ b/tools/server/llama_dflash_bridge.cpp
@@ -0,0 +1,168 @@
+// llama_dflash_bridge.cpp — Phase 0h. See header for scope + TODOs.
+
+#ifdef LLAMA_HAS_DFLASH
+
+#include "llama_dflash_bridge.h"
+
+#include <algorithm>
+#include <cstring>
+#include <stdexcept>
+
+namespace llama_server {
+
+LlamaToDFlashTarget::LlamaToDFlashTarget(struct llama_context * ctx,
+                                          const struct llama_model * model)
+    : ctx_(ctx), model_(model) {
+    vocab_ = llama_model_get_vocab(model_);
+
+    // Capture-layer hint for dflash drafter. Lucebox drafter wants features
+    // from a few evenly-spread layers. Picking 4 evenly across n_layer.
+    // TODO Phase 0h v1: read this from drafter config rather than hardcoding.
+    const int n_layer = llama_model_n_layer(model_);
+    capture_layers_.clear();
+    for (int i = 1; i <= 4; ++i) {
+        capture_layers_.push_back((n_layer * i) / 5);
+    }
+}
+
+LlamaToDFlashTarget::~LlamaToDFlashTarget() {
+    // Drop any leftover snapshot
+    if (snapshot_active_) {
+        llama_memory_seq_rm(llama_get_memory(ctx_), snapshot_seq_id_, -1, -1);
+    }
+}
+
+bool LlamaToDFlashTarget::verify_batch(const std::vector<int32_t> & tokens,
+                                        int base_pos,
+                                        int & last_tok,
+                                        std::vector<int32_t> * all_argmax) {
+    const int n = (int) tokens.size();
+    if (n == 0) {
+        return false;
+    }
+
+    // Build batch. base_pos is the cache position the FIRST token in `tokens`
+    // should be placed at. All tokens belong to live_seq_id_.
+    llama_batch batch = llama_batch_init(n, 0, 1);
+    batch.n_tokens = n;
+    for (int i = 0; i < n; ++i) {
+        batch.token[i]    = tokens[i];
+        batch.pos[i]      = base_pos + i;
+        batch.n_seq_id[i] = 1;
+        batch.seq_id[i][0] = live_seq_id_;
+        batch.logits[i]   = 1;   // request logits for every position (verify needs all argmax)
+    }
+
+    const int rc = llama_decode(ctx_, batch);
+    llama_batch_free(batch);
+    if (rc != 0) {
+        return false;
+    }
+
+    // TODO Phase 0h v1: capture intermediate layer features here.
+    // For v0 we leave the dflash feature ring empty/zero — drafter acceptance
+    // will be poor until real capture is wired in.
+
+    // Argmax for each position
+    const int n_vocab = llama_vocab_n_tokens(vocab_);
+    if (all_argmax) {
+        all_argmax->clear();
+        all_argmax->reserve(n);
+    }
+    for (int i = 0; i < n; ++i) {
+        const float * logits = llama_get_logits_ith(ctx_, i);
+        if (!logits) {
+            return false;
+        }
+        int argmax = 0;
+        float best = logits[0];
+        for (int v = 1; v < n_vocab; ++v) {
+            if (logits[v] > best) {
+                best = logits[v];
+                argmax = v;
+            }
+        }
+        if (all_argmax) {
+            all_argmax->push_back(argmax);
+        }
+        if (i == n - 1) {
+            last_tok = argmax;
+        }
+    }
+    return true;
+}
+
+bool LlamaToDFlashTarget::snapshot_kv() {
+    auto * mem = llama_get_memory(ctx_);
+    if (!mem) return false;
+    // Clear any prior snapshot
+    if (snapshot_active_) {
+        llama_memory_seq_rm(mem, snapshot_seq_id_, -1, -1);
+    }
+    // Copy live → snapshot
+    llama_memory_seq_cp(mem, live_seq_id_, snapshot_seq_id_, -1, -1);
+    snapshot_active_ = true;
+    return true;
+}
+
+bool LlamaToDFlashTarget::restore_kv() {
+    auto * mem = llama_get_memory(ctx_);
+    if (!mem || !snapshot_active_) return false;
+    // Wipe live and restore from snapshot
+    llama_memory_seq_rm(mem, live_seq_id_, -1, -1);
+    llama_memory_seq_cp(mem, snapshot_seq_id_, live_seq_id_, -1, -1);
+    return true;
+}
+
+bool LlamaToDFlashTarget::is_eos(int token) const {
+    return llama_vocab_is_eog(vocab_, (llama_token) token);
+}
+
+bool LlamaToDFlashTarget::embed_tokens(const int32_t * tokens, int n,
+                                        float * out) const {
+    // TODO Phase 0h v1: extract embeddings via the model's tok_embd tensor.
+    // llama.cpp doesn't expose this directly — would need either:
+    //   (a) ggml-side pull from internal model.tok_embd (private)
+    //   (b) decode each token with embeddings output mode and capture
+    //   (c) llama_get_embeddings() after a single-token decode
+    //
+    // For v0 ship blocker: stub with zeros. Draft acceptance drops to chance.
+    if (!out || n <= 0) return false;
+    const int dim = llama_model_n_embd(model_);
+    std::memset(out, 0, sizeof(float) * (size_t) n * (size_t) dim);
+    return true;
+}
+
+bool LlamaToDFlashTarget::project_hidden_to_tokens(const float * hidden,
+                                                    int n_tokens,
+                                                    std::vector<int32_t> & tokens_out) {
+    // TODO Phase 0h v1: apply model.output_norm + model.output to project.
+    // Same access problem as embed_tokens — lm_head weights aren't on the public API.
+    //
+    // Workaround: dflash's drafter normally calls this AFTER it has computed
+    // hidden states. We could instead push the hidden via a dummy llama_batch
+    // with `embeddings_only` mode and read logits, then argmax.
+    //
+    // v0 stub: argmax over zeros → token 0 (or eos). Triggers immediate
+    // drafter rejection → spec-decode falls through to autoregressive on target.
+    tokens_out.assign((size_t) n_tokens, 0);
+    return true;
+}
+
+int LlamaToDFlashTarget::hidden_size() const {
+    return llama_model_n_embd(model_);
+}
+
+int LlamaToDFlashTarget::mask_token_id() const {
+    // Qwen3.5/3.6 uses <|PAD_TOKEN|> as mask sentinel per tokenizer config.
+    // Returning pad_token_id is the closest analog.
+    return (int) llama_vocab_pad(vocab_);
+}
+
+const std::vector<int> & LlamaToDFlashTarget::capture_layer_ids() const {
+    return capture_layers_;
+}
+
+} // namespace llama_server
+
+#endif // LLAMA_HAS_DFLASH
diff --git a/tools/server/llama_dflash_bridge.h b/tools/server/llama_dflash_bridge.h
new file mode 100644
index 00000000..6fbb0dca
--- /dev/null
+++ b/tools/server/llama_dflash_bridge.h
@@ -0,0 +1,76 @@
+// llama_dflash_bridge.h — Phase 0h bridge between llama.cpp and lucebox-hub dflash.
+//
+// Implements dflash27b::DFlashTarget interface against a llama_model + llama_context,
+// letting dflash's run_dflash_spec_decode() drive speculative decoding through our
+// existing llama-cpp inference path.
+//
+// SCOPE:
+//   - target = Qwen3.5/3.6 27B loaded by llama_model (with MTP head + TurboQuant kv)
+//   - drafter = separate (loaded by dflash itself; v0 uses stock lucebox drafter,
+//     v1 will use a trader-aligned 0.6B drafter from Phase 5c)
+//   - feature capture from target's intermediate layers: STUBBED — requires either
+//     custom llama_decode build with layer hooks, or running a parallel ggml graph.
+//     v0 ships with degraded draft acceptance; v1 wires real feature capture.
+//
+// NOT THREAD-SAFE — one bridge per request, single-threaded decode loop.
+
+#pragma once
+
+#ifdef LLAMA_HAS_DFLASH
+
+#include "common/dflash_target.h"
+#include "llama.h"
+
+#include <cstdint>
+#include <vector>
+#include <memory>
+
+namespace llama_server {
+
+// LlamaToDFlashTarget adapts a llama_context to dflash27b::DFlashTarget.
+//
+// Lifetime: must outlive any run_dflash_spec_decode call. Internally manages
+// a snapshot of the llama_context's KV cache state for spec-decode rollback.
+class LlamaToDFlashTarget : public dflash27b::DFlashTarget {
+public:
+    explicit LlamaToDFlashTarget(struct llama_context * ctx,
+                                  const struct llama_model * model);
+    ~LlamaToDFlashTarget() override;
+
+    // DFlashTarget interface
+    bool verify_batch(const std::vector<int32_t> & tokens,
+                      int base_pos,
+                      int & last_tok,
+                      std::vector<int32_t> * all_argmax = nullptr) override;
+
+    bool snapshot_kv() override;
+    bool restore_kv() override;
+    bool is_eos(int token) const override;
+
+    bool embed_tokens(const int32_t * tokens, int n, float * out) const override;
+    bool project_hidden_to_tokens(const float * hidden, int n_tokens,
+                                  std::vector<int32_t> & tokens_out) override;
+
+    int hidden_size() const override;
+    int mask_token_id() const override;
+    const std::vector<int> & capture_layer_ids() const override;
+
+private:
+    struct llama_context * ctx_;
+    const struct llama_model * model_;
+    const struct llama_vocab * vocab_;
+
+    // KV snapshot bookkeeping. llama-cpp's seq_rm + seq_cp pattern.
+    // snapshot_kv() copies seq 0 → seq 1, restore_kv() copies back.
+    int32_t snapshot_seq_id_ = 1;
+    int32_t live_seq_id_ = 0;
+    bool snapshot_active_ = false;
+
+    // Capture layers — for v0 we expose the layer indices dflash's draft expects,
+    // but the actual feature data is fed zeros (TODO: real capture in v1).
+    mutable std::vector<int> capture_layers_;
+};
+
+} // namespace llama_server
+
+#endif // LLAMA_HAS_DFLASH
