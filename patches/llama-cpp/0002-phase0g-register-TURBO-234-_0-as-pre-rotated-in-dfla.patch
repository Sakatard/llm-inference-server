From d6e56ae303f1b074f378f68d28fb5bd9c453c828 Mon Sep 17 00:00:00 2001
From: Sakatard <Sakatard@me.com>
Date: Mon, 18 May 2026 21:42:06 +0800
Subject: [PATCH 2/9] 
 0002-phase0g-register-TURBO-234-_0-as-pre-rotated-in-dfla.patch

---
 .../lucebox-hub/dflash/src/qwen35/qwen35_target_graph.cpp  | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/vendor/lucebox-hub/dflash/src/qwen35/qwen35_target_graph.cpp b/vendor/lucebox-hub/dflash/src/qwen35/qwen35_target_graph.cpp
index 9619066a..d608deec 100644
--- a/vendor/lucebox-hub/dflash/src/qwen35/qwen35_target_graph.cpp
+++ b/vendor/lucebox-hub/dflash/src/qwen35/qwen35_target_graph.cpp
@@ -127,7 +127,12 @@ bool create_target_cache_partial(const TargetWeights & w,
     // Graph-level FWHT K-rotation (TurboQuant-style outlier spreading with
     // standard quant types that keep fast FA kernel paths on all arches).
     // Skip for TQ3_0 K cache — that type already applies WHT during quantization.
-    out.kv_k_rotated = (kv_k_type != GGML_TYPE_TQ3_0);
+    // Sakatard fork: TURBO2_0/TURBO3_0/TURBO4_0 also pre-rotate via WHT + PolarQuant,
+    // so we must NOT double-rotate when those cache types are active.
+    out.kv_k_rotated = (kv_k_type != GGML_TYPE_TQ3_0
+                     && kv_k_type != GGML_TYPE_TURBO2_0
+                     && kv_k_type != GGML_TYPE_TURBO3_0
+                     && kv_k_type != GGML_TYPE_TURBO4_0);
 
     const bool needs_256_stride =
         kv_k_type == GGML_TYPE_TQ3_0 || kv_v_type == GGML_TYPE_TQ3_0;
