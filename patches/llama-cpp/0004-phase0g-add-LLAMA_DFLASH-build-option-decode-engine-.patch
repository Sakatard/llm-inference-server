From a9a8ddf3664caac6dd31c65afe5166199a8ff04b Mon Sep 17 00:00:00 2001
From: build <build@local>
Date: Sat, 16 May 2026 14:51:03 +0800
Subject: [PATCH 04/10] phase0g: add LLAMA_DFLASH build option +
 --decode-engine CLI flag
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

CMakeLists.txt:
  - new option LLAMA_DFLASH (default OFF)
  - when ON: includes vendor/lucebox-hub/dflash/SAKATARD_INTEGRATION.cmake
    after tools/ subdir, then links dflash27b_iface into llama-server with
    LLAMA_HAS_DFLASH=1 compile definition.

common/common.h:
  - new field common_params::decode_engine ("legacy" | "dflash")

common/arg.cpp:
  - new CLI flag --decode-engine ENGINE; validates legacy|dflash; LLAMA_ARG_DECODE_ENGINE env.
  - Exposed to SERVER, CLI, SPECULATIVE examples.

Remaining wire-up (last mile of Phase 0g):
  - tools/server/server-context.cpp: dispatch llama_decode → dflash::decode_batch
    when params.decode_engine == "dflash" AND LLAMA_HAS_DFLASH defined.
  - Need to read dflash's public API surface to identify decode entry point
    (likely dflash::DFlashContext::create + decode_batch from
    common/dflash_spec_decode.h).

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 CMakeLists.txt  | 19 +++++++++++++++++++
 common/arg.cpp  | 12 ++++++++++++
 common/common.h |  4 ++++
 3 files changed, 35 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 244f4cb49..8e25248d6 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -117,6 +117,9 @@ option(LLAMA_TESTS_INSTALL          "llama: install tests"
 option(LLAMA_OPENSSL    "llama: use openssl to support HTTPS" ON)
 option(LLAMA_LLGUIDANCE "llama-common: include LLGuidance library for structured output in common utils" OFF)
 
+# Phase 0g: lucebox-hub dFlash decode engine integration
+option(LLAMA_DFLASH     "llama: build dflash decode engine (lucebox-hub) into llama-server" OFF)
+
 
 # Required for relocatable CMake package
 include(${CMAKE_CURRENT_SOURCE_DIR}/cmake/build-info.cmake)
@@ -216,6 +219,22 @@ if (LLAMA_BUILD_COMMON AND LLAMA_BUILD_TOOLS)
     add_subdirectory(tools)
 endif()
 
+# Phase 0g: vendor lucebox-hub dFlash decode engine
+# Must come AFTER add_subdirectory(tools) so we can append dflash27b_iface
+# to the server target's link list.
+if (LLAMA_DFLASH)
+    set(_dflash_shim "${CMAKE_SOURCE_DIR}/vendor/lucebox-hub/dflash/SAKATARD_INTEGRATION.cmake")
+    if(NOT EXISTS "${_dflash_shim}")
+        message(FATAL_ERROR "LLAMA_DFLASH=ON but ${_dflash_shim} missing — run git subtree pull")
+    endif()
+    include("${_dflash_shim}")
+    if(TARGET dflash27b_iface AND TARGET llama-server)
+        target_link_libraries(llama-server PRIVATE dflash27b_iface)
+        target_compile_definitions(llama-server PRIVATE LLAMA_HAS_DFLASH=1)
+        message(STATUS "Phase 0g: linked dflash27b_iface into llama-server")
+    endif()
+endif()
+
 # Automatically add all files from the 'licenses' directory
 file(GLOB EXTRA_LICENSES "${CMAKE_SOURCE_DIR}/licenses/LICENSE-*")
 
diff --git a/common/arg.cpp b/common/arg.cpp
index 664371562..385e4b934 100644
--- a/common/arg.cpp
+++ b/common/arg.cpp
@@ -2075,6 +2075,18 @@ common_params_context common_params_parser_init(common_params & params, llama_ex
             params.cache_type_v = kv_cache_type_from_str(value);
         }
     ).set_env("LLAMA_ARG_CACHE_TYPE_V"));
+    // Phase 0g: dflash decode engine (requires LLAMA_DFLASH=ON build)
+    add_opt(common_arg(
+        {"--decode-engine"}, "ENGINE",
+        "decode loop engine: 'legacy' (default, standard llama_decode) or 'dflash' "
+        "(lucebox-hub dflash kernels + DDTree verify, requires LLAMA_DFLASH=ON build)",
+        [](common_params & params, const std::string & value) {
+            if (value != "legacy" && value != "dflash") {
+                throw std::invalid_argument("--decode-engine must be 'legacy' or 'dflash', got '" + value + "'");
+            }
+            params.decode_engine = value;
+        }
+    ).set_examples({LLAMA_EXAMPLE_SERVER, LLAMA_EXAMPLE_CLI, LLAMA_EXAMPLE_SPECULATIVE}).set_env("LLAMA_ARG_DECODE_ENGINE"));
     add_opt(common_arg(
         {"--hellaswag"},
         "compute HellaSwag score over random tasks from datafile supplied with -f",
diff --git a/common/common.h b/common/common.h
index dda4973bb..d8553e1f3 100644
--- a/common/common.h
+++ b/common/common.h
@@ -560,6 +560,10 @@ struct common_params {
     ggml_type cache_type_k = GGML_TYPE_F16; // KV cache data type for the K
     ggml_type cache_type_v = GGML_TYPE_F16; // KV cache data type for the V
 
+    // Phase 0g: decode engine selection. "legacy" = standard llama_decode loop.
+    // "dflash" = lucebox-hub dflash decode engine (requires LLAMA_DFLASH build).
+    std::string decode_engine = "legacy";
+
     common_conversation_mode conversation_mode = COMMON_CONVERSATION_MODE_AUTO;
 
     // multimodal models (see tools/mtmd)
