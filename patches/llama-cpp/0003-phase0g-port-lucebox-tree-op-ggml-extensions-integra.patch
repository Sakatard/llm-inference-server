+# SAKATARD_INTEGRATION.cmake — Phase 0g
+# ------------------------------------------------------------------------------
+# Embeds dFlash decode engine sources into the parent Sakatard llama.cpp build
+# as a static library `dflash27b_iface`. llama-server links against it when
+# `LLAMA_DFLASH=ON`.
+#
+# Goals:
+#   - Single binary: dflash kernels compiled into our existing llama-server,
+#     NOT a separate process.
+#   - Pascal sm_61 scalar path only (flashprefill_scalar.cu). No BSA (sm_80+).
+#     No pflash (defer to v1). No megakernel (Qwen3.5-0.8B specific).
+#     No gemma4/laguna/qwen3 drafter (we use MTP head from target, not external).
+#   - Reuse Sakatard's existing TURBO[234]_0 ggml types and ggml-cuda dequant
+#     kernels. dflash's qwen35_target_graph.cpp:130 already patched to recognize
+#     TURBO* as pre-rotated (see commit d07efcee9).
+#   - Avoid lucebox's standalone project() declaration — this file is included
+#     from root CMakeLists.txt via add_library, not add_subdirectory of dflash/CMakeLists.txt.
+#
+# Usage from root CMakeLists.txt:
+#   option(LLAMA_DFLASH "Build dflash decode engine into llama-server" OFF)
+#   if(LLAMA_DFLASH)
+#       include(vendor/lucebox-hub/dflash/SAKATARD_INTEGRATION.cmake)
+#   endif()
+#
+# Then in tools/server/CMakeLists.txt:
+#   if(TARGET dflash27b_iface)
+#       target_link_libraries(${TARGET} PUBLIC dflash27b_iface)
+#       target_compile_definitions(${TARGET} PRIVATE LLAMA_HAS_DFLASH=1)
+#   endif()
+# ------------------------------------------------------------------------------
+
+set(DFLASH_ROOT "${CMAKE_CURRENT_LIST_DIR}")
+set(DFLASH_SRC  "${DFLASH_ROOT}/src")
+
+message(STATUS "Phase 0g: building dflash27b_iface for sm_61 (Pascal scalar)")
+
+# --- Source selection: minimal Pascal-viable subset --------------------------
+# qwen35 target (our model family)
+set(DFLASH_QWEN35_SRC
+    "${DFLASH_SRC}/qwen35/qwen35_target_loader.cpp"
+    "${DFLASH_SRC}/qwen35/qwen35_target_graph.cpp"
+    "${DFLASH_SRC}/qwen35/qwen35_dflash_target.cpp"
+)
+
+# Common runtime: ddtree verify, spec decode, gguf inspect, cache utils
+set(DFLASH_COMMON_SRC
