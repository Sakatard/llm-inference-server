+        const float * __restrict__ src0,        // sx: [K-1+n_t, d_inner, n_s]
+        const float * __restrict__ src1,        // c:  [K, d_inner]
+        const int * __restrict__   parent_ids,  // [n_t, n_s]
+        const int src0_nb0, const int src0_nb1, const int src0_nb2,
+        const int src1_nb1,
