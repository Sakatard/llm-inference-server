+// Phase 0h: expose input-token embedding lookup for dflash bridge.
+// Copies n_tokens rows from model.tok_embd to `out` (f32, [n_tokens * n_embd]).
+// Returns 0 on success, non-zero on error (tok_embd not loaded, type unsupported, etc).
+//
+// Caller must ensure `out` has n_tokens * llama_model_n_embd(model) floats allocated.
+// Supports F32, F16, BF16 tok_embd; other quantized types return error (TODO: add
+// per-type dequant via ggml_internal_get_type_traits if needed for v1).
+int32_t llama_model_embed_input_tokens(
+        const struct llama_model * model,
+        const llama_token *        tokens,
+        int32_t                    n_tokens,
+        float *                    out) {
+    if (!model || !tokens || !out || n_tokens <= 0) {
+        return 1;
+    }
+    const ggml_tensor * tok_embd = model->tok_embd;
+    if (!tok_embd) {
+        return 2;  // tok_embd not loaded (encoder-decoder w/ shared embed?)
+    }
+    const int64_t n_embd   = tok_embd->ne[0];
+    const int64_t n_vocab  = tok_embd->ne[1];
+    const size_t  row_size = ggml_row_size(tok_embd->type, n_embd);
+
+    std::vector<uint8_t> row_buf(row_size);
+
+    for (int32_t i = 0; i < n_tokens; i++) {
+        const llama_token t = tokens[i];
+        if (t < 0 || (int64_t) t >= n_vocab) {
+            return 3;  // out-of-range token
+        }
+        // Pull row from backend (handles GPU residency)
+        ggml_backend_tensor_get(tok_embd, row_buf.data(),
+                                 (size_t) t * row_size, row_size);
+        // Convert row to f32 into out[i * n_embd ...]
+        float * dst = out + (size_t) i * n_embd;
+        const enum ggml_type t_ = tok_embd->type;
+        if (t_ == GGML_TYPE_F32) {
+            std::memcpy(dst, row_buf.data(), sizeof(float) * n_embd);
+        } else if (t_ == GGML_TYPE_F16) {
+            const ggml_fp16_t * src = (const ggml_fp16_t *) row_buf.data();
+            for (int64_t j = 0; j < n_embd; j++) {
+                dst[j] = ggml_fp16_to_fp32(src[j]);
+            }
+        } else if (t_ == GGML_TYPE_BF16) {
+            const ggml_bf16_t * src = (const ggml_bf16_t *) row_buf.data();
+            for (int64_t j = 0; j < n_embd; j++) {
+                dst[j] = ggml_bf16_to_fp32(src[j]);
+            }
+        } else {
+            // Quantized types — would need block dequant; not v0 scope
+            return 4;
+        }
+    }
+    return 0;
+}
+
